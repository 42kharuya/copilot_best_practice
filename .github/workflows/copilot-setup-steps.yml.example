name: "Copilot Environment Setup"
description: "クラウドエージェント（Copilot）向けの開発環境セットアップ定義"

on:
  workflow_dispatch:
  push:
    paths:
      - .github/workflows/copilot-setup-steps.yml
  pull_request:
    paths:
      - .github/workflows/copilot-setup-steps.yml

jobs:
  copilot-setup-steps:
    runs-on: ubuntu-latest
    permissions:
      contents: read
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      # ※注意: 以下はプロジェクトの言語（Node.js, Python等）に合わせて変更してください
      # 例えばNode.jsプロジェクトの場合の最小構成:
      # - name: Setup Node.js
      #   uses: actions/setup-node@v4
      #   with:
      #     node-version: '20'
      #
      # - name: Install dependencies
      #   run: npm ci

      - name: Echo Setup Info
        run: echo "Add setup steps here for Copilot Cloud Agent."
